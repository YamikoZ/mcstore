Options -Indexes
RewriteEngine On

# ไฟล์/โฟลเดอร์จริง (CSS, JS, รูป) → ส่งตรง
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ยกเว้น assets และ uploads
RewriteCond %{REQUEST_URI} !/(assets|uploads)/ [NC]

# ทุกอย่างเข้า index.php (ทำงานได้ทั้ง root และ subfolder โดยไม่ต้อง RewriteBase)
RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
